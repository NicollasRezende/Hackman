# OBRIGATÓRIO: ID do número de telefone WhatsApp
# Encontre em: WhatsApp Business Platform > Phone Numbers
WHATSAPP_PHONE_NUMBER_ID=780592421814828

# OPCIONAL: ID da conta Business (usado para algumas operações avançadas)
WHATSAPP_BUSINESS_ACCOUNT_ID=1433289308413687

# OPCIONAL: Token de verificação para webhooks
# Você define este valor e usa para verificar webhooks
WHATSAPP_VERIFY_TOKEN=TAGVALUE

# ==================================================
# API Configuration
# ==================================================

# Versão da API do WhatsApp (padrão: v18.0)
WHATSAPP_API_VERSION=v22.0

# URL base da API (padrão: https://graph.facebook.com)
WHATSAPP_BASE_URL=https://graph.facebook.com

# ==================================================
# Connection Settings
# ==================================================

# Timeout para requests em segundos (padrão: 30)
WHATSAPP_TIMEOUT=30

# Número máximo de tentativas em caso de falha (padrão: 3)
WHATSAPP_MAX_RETRIES=3

# ==================================================
# Logging Settings
# ==================================================

# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
WHATSAPP_LOG_LEVEL=INFO

# Log de requests HTTP (true/false)
WHATSAPP_LOG_REQUESTS=true

# Log de responses HTTP (true/false)
WHATSAPP_LOG_RESPONSES=true

# ==================================================
# INSTRUÇÕES PARA OBTER CREDENCIAIS
# ==================================================
#
# 1. Acesse: https://developers.facebook.com/
# 2. Crie ou selecione um App
# 3. Adicione o produto "WhatsApp"
# 4. Em "API Setup", você encontrará:
#    - Access Token (temporário 24h ou permanente)
#    - Phone Number ID
#    - WhatsApp Business Account ID
#
# 5. Para token permanente:
#    - Vá em "System Users" no Business Manager
#    - Gere token com permissões: whatsapp_business_messaging
#
# 6. Configure webhook:
#    - URL: https://seu-dominio.com/webhooks/whatsapp
#    - Verify Token: o valor que você definiu acima
#    - Subscribe to: messages, message_status
#
# ==================================================
