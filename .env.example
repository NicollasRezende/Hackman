# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8080/api

# --- Backend (copie para backend/.env ou raiz conforme spring.config.import) ---
SERVER_PORT=8080

# LLM: configure pelo menos um provedor
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=groq/compound
GROQ_TIMEOUT=45
GROQ_MAX_TOKENS=1500
GROQ_TEMPERATURE=0.3

OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-thinking:free
OPENROUTER_TIMEOUT_SECONDS=30
OPENROUTER_MAX_TOKENS=1500
OPENROUTER_TEMPERATURE=0.3

PORTAL_TRANSPARENCIA_API_KEY=

# CORS: origens do Vite (adicione a sua porta se diferente)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173

# Métricas TCU / painel admin (opcional)
GUIA_FISCAL_CUSTO_MIN=40
GUIA_FISCAL_CUSTO_MAX=80
GUIA_INVESTIMENTO_SISTEMA_REAIS=0
GUIA_RELEASE_VERSION=1.0.0-demo
